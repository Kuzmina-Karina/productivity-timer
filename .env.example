# Salute Assistant Token для режима разработки (SmartApp Studio / кабинет разработчика)
# SmartApp → вкладка «Эмулятор» → ключ. Без него на localhost не будет отладочной панели (ввод / микрофон).
REACT_APP_TOKEN=

# Фраза запуска смартапа в эмуляторе (любая, приближенная к тому как вы дергаете навык в Studio).
# REACT_APP_INIT_PHRASE=Запусти голосовой таймер

# Остальные переменные (опциональные)
NODE_ENV=development
