  "nlu_config": {
    "language": "ru-RU",
    "locale": "ru_RU",
    "grammar_rules": [
      {
        "pattern": "запусти|включи|установи",
        "weight": 1.0,
        "type": "trigger"
      },
      {
        "pattern": "таймер",
        "weight": 0.8,
        "type": "context"
      },
      {
        "pattern": "секунд|секунды|сек",
        "weight": 1.0,
        "type": "unit",
        "normalizes_to": "seconds"
      },
      {
        "pattern": "минут|минуты|мин",
        "weight": 1.0,
        "type": "unit",
        "normalizes_to": "minutes"
      },
      {
        "pattern": "на",
        "weight": 0.5,
        "type": "preposition"
      }
    ],
    "number_recognition": {
      "enabled": true,
      "support_words": true,
      "examples": [
        "одна",
        "два",
        "три",
        "четыре",
        "пять",
        "десять",
        "пятнадцать",
        "тридцать",
        "сорок",
        "пятьдесят",
        "шестьдесят"
      ]
    }
  },
