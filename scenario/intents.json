{
  "name": "Таймер",
  "version": "1.0.0",
  "intents": [
    {
      "id": "set_timer",
      "patterns": [
        "запусти таймер на {time}",
        "включи таймер на {time}",
        "установи таймер на {time}",
        "таймер на {time}",
        "таймер {time}",
        "запусти отсчёт на {time}",
        "на {time}"
      ],
      "slots": [
        {
          "name": "time",
          "type": "duration",
          "required": true
        }
      ]
    },
    {
      "id": "cancel_timer",
      "patterns": [
        "останови таймер",
        "стоп",
        "прекрати отсчёт",
        "прекрати отсчет",
        "выключи таймер",
        "отключи таймер",
        "отмени таймер",
        "отмена"
      ]
    }
  ],
  "entities": [
    {
      "name": "duration",
      "type": "composite",
      "examples": [
        "30 секунд",
        "5 минут",
        "2 минуты",
        "одна минута",
        "две минуты",
        "полчаса"
      ]
    }
  ]
}
